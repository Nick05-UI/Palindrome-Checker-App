import java.util.Scanner;
import java.util.Stack;
import java.util.Queue;
import java.util.LinkedList;
import java.util.Deque;
import java.util.ArrayDeque;

interface PalindromeStrategy {
    boolean check(String input);
    String name();
}

class RecursiveStrategy implements PalindromeStrategy {
    private boolean recurse(String s, int l, int r) {
        if (l >= r) return true;
        if (s.charAt(l) != s.charAt(r)) return false;
        return recurse(s, l + 1, r - 1);
    }
    public boolean check(String s) { return recurse(s, 0, s.length() - 1); }
    public String name() { return "Recursive"; }
}

class CharArrayStrategy implements PalindromeStrategy {
    public boolean check(String s) {
        char[] ch = s.toCharArray();
        int l = 0, r = ch.length - 1;
        while (l < r) { if (ch[l++] != ch[r--]) return false; }
        return true;
    }
    public String name() { return "CharArray (Two-Pointer)"; }
}

class StackStrategy implements PalindromeStrategy {
    public boolean check(String s) {
        Stack<Character> st = new Stack<>();
        for (char c : s.toCharArray()) st.push(c);
        String rev = "";
        while (!st.isEmpty()) rev += st.pop();
        return s.equals(rev);
    }
    public String name() { return "Stack (LIFO)"; }
}

class QueueStackStrategy implements PalindromeStrategy {
    public boolean check(String s) {
        Stack<Character> st = new Stack<>();
        Queue<Character> q  = new LinkedList<>();
        for (char c : s.toCharArray()) { st.push(c); q.add(c); }
        while (!st.isEmpty()) if (st.pop() != q.poll()) return false;
        return true;
    }
    public String name() { return "Queue + Stack"; }
}

class DequeStrategy implements PalindromeStrategy {
    public boolean check(String s) {
        Deque<Character> d = new ArrayDeque<>();
        for (char c : s.toCharArray()) d.addLast(c);
        while (d.size() > 1) if (d.removeFirst() != d.removeLast()) return false;
        return true;
    }
    public String name() { return "Deque (Front & Rear)"; }
}

class LinkedListStrategy implements PalindromeStrategy {
    static class Node { char data; Node next; Node(char d) { data = d; } }
    private Node build(String s) {
        Node head = null, tail = null;
        for (char c : s.toCharArray()) {
            Node n = new Node(c);
            if (head == null) { head = tail = n; } else { tail.next = n; tail = n; }
        }
        return head;
    }
    private Node reverse(Node h) {
        Node p = null, c = h;
        while (c != null) { Node nx = c.next; c.next = p; p = c; c = nx; }
        return p;
    }
    public boolean check(String s) {
        Node head = build(s), slow = head, fast = head;
        while (fast != null && fast.next != null) { slow = slow.next; fast = fast.next.next; }
        Node sec = reverse(slow), fir = build(s);
        while (sec != null) { if (fir.data != sec.data) return false; fir = fir.next; sec = sec.next; }
        return true;
    }
    public String name() { return "Linked List"; }
}

class StringBuilderStrategy implements PalindromeStrategy {
    public boolean check(String s) { return s.equals(new StringBuilder(s).reverse().toString()); }
    public String name() { return "StringBuilder"; }
}

class PalindromeLogic {
    private String original;
    private String normalized;
    private PalindromeStrategy strategy;

    public PalindromeLogic(String input, PalindromeStrategy strategy) {
        this.original   = input;
        this.normalized = input.toLowerCase().replaceAll("[^a-z0-9]", "");
        this.strategy   = strategy;
    }

    public void setStrategy(PalindromeStrategy s) { this.strategy = s; }
    public String getOriginal()    { return original;   }
    public String getNormalized()  { return normalized;  }
    public String getStrategyName(){ return strategy.name(); }
    public boolean checkPalindrome() { return strategy.check(normalized); }
}

class PerformanceBenchmark {
    private static final int WARMUP_RUNS = 1000;
    private static final int BENCH_RUNS  = 10000;

    public static long measure(PalindromeStrategy strategy, String input) {
        for (int i = 0; i < WARMUP_RUNS; i++) strategy.check(input);
        long start = System.nanoTime();
        for (int i = 0; i < BENCH_RUNS; i++) strategy.check(input);
        return (System.nanoTime() - start) / BENCH_RUNS;
    }

    public static void run(String input, PalindromeStrategy[] strategies) {
        System.out.println("Input      : " + input);
        System.out.println("Normalized : " + input.toLowerCase().replaceAll("[^a-z0-9]", ""));
        System.out.println("Runs       : " + BENCH_RUNS + " (warmup: " + WARMUP_RUNS + ")");
        System.out.println();
        System.out.printf("%-32s %-12s %-10s %-6s%n", "Strategy", "Time (ns)", "Result", "Rank");
        System.out.println("-".repeat(64));

        long[]   times   = new long[strategies.length];
        boolean[] results = new boolean[strategies.length];
        String   norm    = input.toLowerCase().replaceAll("[^a-z0-9]", "");

        for (int i = 0; i < strategies.length; i++) {
            times[i]   = measure(strategies[i], norm);
            results[i] = strategies[i].check(norm);
        }

        long   minTime = Long.MAX_VALUE;
        long   maxTime = Long.MIN_VALUE;
        for (long t : times) { minTime = Math.min(minTime, t); maxTime = Math.max(maxTime, t); }

        int[] ranks = new int[strategies.length];
        for (int i = 0; i < times.length; i++) {
            int rank = 1;
            for (long t : times) if (t < times[i]) rank++;
            ranks[i] = rank;
        }

        for (int i = 0; i < strategies.length; i++) {
            String bar  = times[i] == minTime ? " << fastest" : times[i] == maxTime ? " >> slowest" : "";
            System.out.printf("%-32s %-12d %-10s #%d%s%n",
                strategies[i].name(), times[i], results[i], ranks[i], bar);
        }
        System.out.println("-".repeat(64));
        System.out.printf("%-32s %-12d%n", "Fastest", minTime);
        System.out.printf("%-32s %-12d%n", "Slowest", maxTime);
        System.out.printf("%-32s %-12.2f%n%n", "Slowest/Fastest ratio", (double) maxTime / minTime);
    }
}

public class PalindromeChecker {

    static String reverseString(String s) {
        String r = "";
        for (int i = s.length() - 1; i >= 0; i--) r += s.charAt(i);
        return r;
    }

    static class Node { char data; Node next; Node(char d) { data = d; } }
    static Node buildList(String s) {
        Node head = null, tail = null;
        for (char c : s.toCharArray()) {
            Node n = new Node(c);
            if (head == null) { head = tail = n; } else { tail.next = n; tail = n; }
        }
        return head;
    }
    static Node reverseList(Node head) {
        Node prev = null, curr = head;
        while (curr != null) { Node nx = curr.next; curr.next = prev; prev = curr; curr = nx; }
        return prev;
    }
    static void printList(Node head) {
        System.out.print("[");
        for (Node c = head; c != null; c = c.next)
            System.out.print("'" + c.data + "'" + (c.next != null ? " -> " : ""));
        System.out.println("]");
    }

    static PalindromeStrategy[] allStrategies() {
        return new PalindromeStrategy[]{
            new RecursiveStrategy(), new CharArrayStrategy(), new StackStrategy(),
            new QueueStackStrategy(), new DequeStrategy(),
            new LinkedListStrategy(), new StringBuilderStrategy()
        };
    }

    public static void main(String[] args) {

        System.out.println("--- UC2: Hardcoded String Check ---");
        String w2 = "madam";
        System.out.println(w2 + (w2.equals(new StringBuilder(w2).reverse().toString()) ? " is" : " is not") + " a palindrome.");

        System.out.println("\n--- UC3: Reverse Using Loop ---");
        String w3 = "racecar", r3 = reverseString(w3);
        System.out.println("Original : " + w3 + "\nReversed : " + r3);
        System.out.println(w3 + (w3.equals(r3) ? " is" : " is not") + " a palindrome.");

        System.out.println("\n--- UC4: Two-Pointer Char Array ---");
        String w4 = "level";
        char[] ch = w4.toCharArray();
        System.out.print("Char[] : [");
        for (int i = 0; i < ch.length; i++) System.out.print(ch[i] + (i < ch.length - 1 ? ", " : ""));
        System.out.println("]");
        for (int s = 0, e = ch.length - 1; s < e; s++, e--)
            System.out.println("  chars[" + s + "]='" + ch[s] + "'  vs  chars[" + e + "]='" + ch[e] + "'");
        System.out.println(w4 + (new PalindromeLogic(w4, new CharArrayStrategy()).checkPalindrome() ? " is" : " is not") + " a palindrome.");

        System.out.println("\n--- UC5: Stack-Based Check ---");
        String w5 = "noon";
        Stack<Character> st5 = new Stack<>();
        for (char c : w5.toCharArray()) { st5.push(c); System.out.println("  Pushed : '" + c + "'  Stack: " + st5); }
        String popped = "";
        while (!st5.isEmpty()) { char c = st5.pop(); popped += c; System.out.println("  Popped : '" + c + "'  Reversed so far: " + popped); }
        System.out.println(w5 + (new PalindromeLogic(w5, new StackStrategy()).checkPalindrome() ? " is" : " is not") + " a palindrome.");

        System.out.println("\n--- UC6: Queue vs Stack (FIFO vs LIFO) ---");
        String w6 = "civic";
        Stack<Character> s6 = new Stack<>(); Queue<Character> q6 = new LinkedList<>();
        for (char c : w6.toCharArray()) { s6.push(c); q6.add(c); }
        System.out.println("Stack (LIFO) : " + s6 + "\nQueue (FIFO) : " + q6);
        Stack<Character> ts = new Stack<>(); Queue<Character> tq = new LinkedList<>();
        for (char c : w6.toCharArray()) { ts.push(c); tq.add(c); }
        boolean m6 = true;
        while (!ts.isEmpty()) {
            char fs = ts.pop(), fq = tq.poll();
            System.out.println("  pop='" + fs + "'  poll='" + fq + "'  Match: " + (fs == fq));
            if (fs != fq) m6 = false;
        }
        System.out.println(w6 + (m6 ? " is" : " is not") + " a palindrome.");

        System.out.println("\n--- UC7: Deque Front & Rear Comparison ---");
        String w7 = "rotator";
        Deque<Character> td = new ArrayDeque<>();
        for (char c : w7.toCharArray()) td.addLast(c);
        System.out.println("Deque : " + td);
        int st7 = 1; boolean m7 = true;
        while (td.size() > 1) {
            char f = td.removeFirst(), r = td.removeLast();
            System.out.println("  Step " + st7++ + " : '" + f + "' vs '" + r + "'  Match: " + (f == r));
            if (f != r) m7 = false;
        }
        if (td.size() == 1) System.out.println("  Center : '" + td.peekFirst() + "' (skipped)");
        System.out.println(w7 + (m7 ? " is" : " is not") + " a palindrome.");

        System.out.println("\n--- UC8: Singly Linked List ---");
        String w8 = "kayak";
        System.out.print("Linked List : "); printList(buildList(w8));
        Node sl = buildList(w8), fa = sl;
        while (fa != null && fa.next != null) {
            System.out.println("  slow='" + sl.data + "'  fast='" + fa.data + "'");
            sl = sl.next; fa = fa.next.next;
        }
        System.out.println("  Middle : '" + sl.data + "'");
        Node h2 = buildList(w8), s2 = h2, f2 = h2;
        while (f2 != null && f2.next != null) { s2 = s2.next; f2 = f2.next.next; }
        System.out.print("Second half reversed : "); printList(reverseList(s2));
        System.out.println(w8 + (new PalindromeLogic(w8, new LinkedListStrategy()).checkPalindrome() ? " is" : " is not") + " a palindrome.");

        System.out.println("\n--- UC9: Recursive Check ---");
        String w9 = "refer";
        for (int s = 0, e = w9.length() - 1; s <= e; s++, e--)
            System.out.println(s == e
                ? "  call(" + s + "," + e + ") --> base case '" + w9.charAt(s) + "'"
                : "  call(" + s + "," + e + ") --> '" + w9.charAt(s) + "' vs '" + w9.charAt(e) + "'");
        System.out.println(w9 + (new PalindromeLogic(w9, new RecursiveStrategy()).checkPalindrome() ? " is" : " is not") + " a palindrome.");

        System.out.println("\n--- UC10: Ignore Spaces & Case ---");
        for (String t : new String[]{ "A man a plan a canal Panama", "Was it a car or a cat I saw", "Hello World" }) {
            PalindromeLogic pl = new PalindromeLogic(t, new RecursiveStrategy());
            System.out.println("Original   : " + pl.getOriginal());
            System.out.println("Normalized : " + pl.getNormalized());
            System.out.println("Result     : " + t + (pl.checkPalindrome() ? " is" : " is not") + " a palindrome.\n");
        }

        System.out.println("--- UC11: Encapsulated PalindromeLogic Class ---");
        for (String t : new String[]{ "madam", "A Santa at NASA", "hello" }) {
            PalindromeLogic pl = new PalindromeLogic(t, new RecursiveStrategy());
            System.out.println("Input      : " + pl.getOriginal() + "  |  Normalized : " + pl.getNormalized());
            for (PalindromeStrategy strat : allStrategies()) {
                pl.setStrategy(strat);
                System.out.println("  " + strat.name() + " : " + pl.checkPalindrome());
            }
            pl.setStrategy(new RecursiveStrategy());
            System.out.println("Result     : " + t + (pl.checkPalindrome() ? " is" : " is not") + " a palindrome.\n");
        }

        System.out.println("--- UC12: Strategy Pattern ---");
        for (String t : new String[]{ "racecar", "A man a plan a canal Panama", "hello" }) {
            PalindromeLogic pl = new PalindromeLogic(t, new RecursiveStrategy());
            System.out.println("Input : " + pl.getOriginal() + "  |  Normalized : " + pl.getNormalized());
            for (PalindromeStrategy strat : allStrategies()) {
                pl.setStrategy(strat);
                System.out.println("  [" + strat.name() + "] --> " + (pl.checkPalindrome() ? "palindrome" : "not palindrome"));
            }
            System.out.println();
        }

        System.out.println("--- UC13: Performance Benchmark ---");
        String[] benchInputs = {
            "madam",
            "amanaplanacanalpanama",
            "amanaplanacanalpanamawithalongertailtoincreaseload"
        };
        for (String input : benchInputs)
            PerformanceBenchmark.run(input, allStrategies());

        System.out.println("================================");
        System.out.println("     PALINDROME CHECKER v1.0    ");
        System.out.println("================================");
        System.out.println("Select strategy:");
        System.out.println("  1.Recursive  2.CharArray  3.Stack");
        System.out.println("  4.Queue+Stack  5.Deque  6.LinkedList  7.StringBuilder");
        System.out.println("Type 'exit' to quit.");
        System.out.println("--------------------------------");

        PalindromeStrategy[] menu = allStrategies();
        Scanner scanner = new Scanner(System.in);
        int total = 0, palindromes = 0;
        PalindromeStrategy chosen = new RecursiveStrategy();

        while (true) {
            System.out.print("\nStrategy (1-7) or Enter to keep [" + chosen.name() + "]: ");
            String line = scanner.nextLine().trim();
            if (line.equalsIgnoreCase("exit")) break;
            if (!line.isEmpty()) {
                int pick = Integer.parseInt(line) - 1;
                if (pick >= 0 && pick < menu.length) chosen = menu[pick];
            }
            System.out.print("Enter a word or phrase: ");
            String input = scanner.nextLine();
            if (input.equalsIgnoreCase("exit")) break;
            total++;
            PalindromeLogic pl = new PalindromeLogic(input, chosen);
            long time = PerformanceBenchmark.measure(chosen, pl.getNormalized());
            boolean result = pl.checkPalindrome();
            if (result) { palindromes++; System.out.println("✓ \"" + input + "\" IS a palindrome!  [" + chosen.name() + " | " + time + " ns]"); }
            else        {                System.out.println("✗ \"" + input + "\" is NOT a palindrome.  [" + chosen.name() + " | " + time + " ns]"); }
            System.out.println("  Stats: " + palindromes + "/" + total + " palindromes found");
        }

        System.out.println("\n--- Session Summary ---");
        System.out.println("Total checked  : " + total);
        System.out.println("Palindromes    : " + palindromes);
        System.out.println("Not palindromes: " + (total - palindromes));
        System.out.println("Thanks for using Palindrome Checker!");
        scanner.close();
    }
}
