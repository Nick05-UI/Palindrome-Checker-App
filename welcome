import java.util.Scanner;
import java.util.Stack;
import java.util.Queue;
import java.util.LinkedList;
import java.util.Deque;
import java.util.ArrayDeque;

public class PalindromeChecker {

    // UC8: Singly Linked List Node
    static class Node {
        char data;
        Node next;
        Node(char data) {
            this.data = data;
            this.next = null;
        }
    }

    // UC8: Build linked list from string
    public static Node buildLinkedList(String input) {
        Node head = null;
        Node tail = null;
        for (int i = 0; i < input.length(); i++) {
            Node newNode = new Node(input.charAt(i));
            if (head == null) {
                head = newNode;
                tail = newNode;
            } else {
                tail.next = newNode;
                tail = newNode;
            }
        }
        return head;
    }

    // UC8: Print linked list
    public static void printLinkedList(Node head) {
        Node curr = head;
        System.out.print("[");
        while (curr != null) {
            System.out.print("'" + curr.data + "'");
            if (curr.next != null) System.out.print(" -> ");
            curr = curr.next;
        }
        System.out.println("]");
    }

    // UC8: Reverse a linked list
    public static Node reverseList(Node head) {
        Node prev = null;
        Node curr = head;
        while (curr != null) {
            Node nextNode = curr.next;
            curr.next = prev;
            prev = curr;
            curr = nextNode;
        }
        return prev;
    }

    // UC8: Palindrome check using singly linked list
    public static boolean isPalindromeLinkedList(String input) {
        Node head = buildLinkedList(input);

        // Step 1: Find middle using fast and slow pointers
        Node slow = head;
        Node fast = head;
        while (fast != null && fast.next != null) {
            slow = slow.next;
            fast = fast.next.next;
        }

        // Step 2: Reverse second half
        Node secondHalf = reverseList(slow);

        // Step 3: Compare both halves
        Node first  = head;
        Node second = secondHalf;
        while (second != null) {
            if (first.data != second.data) return false;
            first  = first.next;
            second = second.next;
        }
        return true;
    }

    // UC7: Deque-based palindrome check
    public static boolean isPalindromeDeque(String input) {
        Deque<Character> deque = new ArrayDeque<>();
        for (int i = 0; i < input.length(); i++) {
            deque.addLast(input.charAt(i));
        }
        while (deque.size() > 1) {
            if (deque.removeFirst() != deque.removeLast()) return false;
        }
        return true;
    }

    // UC6: Queue vs Stack (FIFO vs LIFO) palindrome check
    public static boolean isPalindromeQueueStack(String input) {
        Stack<Character> stack = new Stack<>();
        Queue<Character> queue = new LinkedList<>();
        for (int i = 0; i < input.length(); i++) {
            stack.push(input.charAt(i));
            queue.add(input.charAt(i));
        }
        while (!stack.isEmpty()) {
            if (stack.pop() != queue.poll()) return false;
        }
        return true;
    }

    // UC5: Stack-based palindrome check
    public static boolean isPalindromeStack(String input) {
        Stack<Character> stack = new Stack<>();
        for (int i = 0; i < input.length(); i++) {
            stack.push(input.charAt(i));
        }
        String reversed = "";
        while (!stack.isEmpty()) {
            reversed = reversed + stack.pop();
        }
        return input.equals(reversed);
    }

    // UC4: Two-pointer approach using char array
    public static boolean isPalindromeCharArray(String input) {
        char[] chars = input.toCharArray();
        int start = 0;
        int end = chars.length - 1;
        while (start < end) {
            if (chars[start] != chars[end]) return false;
            start++;
            end--;
        }
        return true;
    }

    // UC3: Reverse using for loop + string concatenation
    public static String reverseString(String input) {
        String reversed = "";
        for (int i = input.length() - 1; i >= 0; i--) {
            reversed = reversed + input.charAt(i);
        }
        return reversed;
    }

    // UC1 & UC2: Reverse using StringBuilder
    public static boolean isPalindrome(String input) {
        String cleaned = input.toLowerCase().replaceAll("[^a-z0-9]", "");
        String reversed = new StringBuilder(cleaned).reverse().toString();
        return cleaned.equals(reversed);
    }

    public static void main(String[] args) {

        // UC2: Hardcoded string check
        System.out.println("--- UC2: Hardcoded String Check ---");
        String word = "madam";
        String reversedWord = new StringBuilder(word).reverse().toString();
        if (word.equals(reversedWord)) {
            System.out.println(word + " is a palindrome.");
        } else {
            System.out.println(word + " is not a palindrome.");
        }

        // UC3: Reverse using for loop and check
        System.out.println("\n--- UC3: Reverse Using Loop ---");
        String testWord = "racecar";
        String reversedLoop = reverseString(testWord);
        System.out.println("Original : " + testWord);
        System.out.println("Reversed : " + reversedLoop);
        if (testWord.equals(reversedLoop)) {
            System.out.println(testWord + " is a palindrome.");
        } else {
            System.out.println(testWord + " is not a palindrome.");
        }

        // UC4: Two-pointer approach using char array
        System.out.println("\n--- UC4: Two-Pointer Char Array ---");
        String charTestWord = "level";
        char[] chars = charTestWord.toCharArray();
        System.out.println("Original : " + charTestWord);
        System.out.print("Char[]   : [");
        for (int i = 0; i < chars.length; i++) {
            System.out.print(chars[i]);
            if (i < chars.length - 1) System.out.print(", ");
        }
        System.out.println("]");
        int start = 0;
        int end = chars.length - 1;
        System.out.println("Comparing pointers:");
        while (start < end) {
            System.out.println("  chars[" + start + "] = '" + chars[start] + "'  vs  chars[" + end + "] = '" + chars[end] + "'");
            start++;
            end--;
        }
        if (isPalindromeCharArray(charTestWord)) {
            System.out.println(charTestWord + " is a palindrome.");
        } else {
            System.out.println(charTestWord + " is not a palindrome.");
        }

        // UC5: Stack-based palindrome check
        System.out.println("\n--- UC5: Stack-Based Check ---");
        String stackTestWord = "noon";
        Stack<Character> stack = new Stack<>();
        System.out.println("Original : " + stackTestWord);
        for (int i = 0; i < stackTestWord.length(); i++) {
            stack.push(stackTestWord.charAt(i));
            System.out.println("  Pushed : '" + stackTestWord.charAt(i) + "'  Stack: " + stack);
        }
        String popped = "";
        while (!stack.isEmpty()) {
            char c = stack.pop();
            popped = popped + c;
            System.out.println("  Popped : '" + c + "'  Reversed so far: " + popped);
        }
        System.out.println("Reversed : " + popped);
        if (isPalindromeStack(stackTestWord)) {
            System.out.println(stackTestWord + " is a palindrome.");
        } else {
            System.out.println(stackTestWord + " is not a palindrome.");
        }

        // UC6: Queue vs Stack (FIFO vs LIFO)
        System.out.println("\n--- UC6: Queue vs Stack (FIFO vs LIFO) ---");
        String uc6Word = "civic";
        Stack<Character> uc6Stack = new Stack<>();
        Queue<Character> uc6Queue = new LinkedList<>();
        System.out.println("Original : " + uc6Word);
        for (int i = 0; i < uc6Word.length(); i++) {
            uc6Stack.push(uc6Word.charAt(i));
            uc6Queue.add(uc6Word.charAt(i));
        }
        System.out.println("Stack (LIFO) after push    : " + uc6Stack);
        System.out.println("Queue (FIFO) after enqueue : " + uc6Queue);
        System.out.println("\nComparing pop (LIFO) vs dequeue (FIFO):");
        Stack<Character> tempStack = new Stack<>();
        Queue<Character> tempQueue = new LinkedList<>();
        for (int i = 0; i < uc6Word.length(); i++) {
            tempStack.push(uc6Word.charAt(i));
            tempQueue.add(uc6Word.charAt(i));
        }
        boolean match = true;
        while (!tempStack.isEmpty()) {
            char fromStack = tempStack.pop();
            char fromQueue = tempQueue.poll();
            System.out.println("  Stack.pop() = '" + fromStack + "'  Queue.poll() = '" + fromQueue + "'  Match: " + (fromStack == fromQueue));
            if (fromStack != fromQueue) match = false;
        }
        System.out.println("\nResult : " + (match ? uc6Word + " is a palindrome." : uc6Word + " is not a palindrome."));

        // UC7: Deque-based palindrome check
        System.out.println("\n--- UC7: Deque Front & Rear Comparison ---");
        String dequeWord = "rotator";
        Deque<Character> deque = new ArrayDeque<>();
        System.out.println("Original : " + dequeWord);
        for (int i = 0; i < dequeWord.length(); i++) {
            deque.addLast(dequeWord.charAt(i));
        }
        System.out.println("Deque after insert : " + deque);
        System.out.println("\nComparing front and rear:");
        Deque<Character> tempDeque = new ArrayDeque<>();
        for (int i = 0; i < dequeWord.length(); i++) {
            tempDeque.addLast(dequeWord.charAt(i));
        }
        boolean dequeMatch = true;
        int step = 1;
        while (tempDeque.size() > 1) {
            char front = tempDeque.removeFirst();
            char rear  = tempDeque.removeLast();
            System.out.println("  Step " + step + " : front = '" + front + "'  rear = '" + rear + "'  Match: " + (front == rear));
            if (front != rear) dequeMatch = false;
            step++;
        }
        if (tempDeque.size() == 1) {
            System.out.println("  Center : '" + tempDeque.peekFirst() + "' (middle character, skipped)");
        }
        System.out.println("\nResult : " + (dequeMatch ? dequeWord + " is a palindrome." : dequeWord + " is not a palindrome."));

        // UC8: Singly Linked List palindrome check
        System.out.println("\n--- UC8: Singly Linked List ---");
        String listWord = "kayak";
        System.out.println("Original : " + listWord);

        Node head = buildLinkedList(listWord);
        System.out.print("Linked List        : ");
        printLinkedList(head);

        // Find middle using fast and slow pointers
        Node slow = head;
        Node fast = head;
        int slowSteps = 0;
        System.out.println("\nFinding middle (fast & slow pointer):");
        while (fast != null && fast.next != null) {
            System.out.println("  slow -> '" + slow.data + "'  fast -> '" + fast.data + "'");
            slow = slow.next;
            fast = fast.next.next;
            slowSteps++;
        }
        System.out.println("  Middle node reached at : '" + slow.data + "'");

        // Rebuild for reversal display
        Node head2      = buildLinkedList(listWord);
        Node slow2      = head2;
        Node fast2      = head2;
        while (fast2 != null && fast2.next != null) {
            slow2 = slow2.next;
            fast2 = fast2.next.next;
        }
        Node secondHalf = reverseList(slow2);
        System.out.print("Second half reversed : ");
        printLinkedList(secondHalf);

        // Compare halves
        System.out.println("\nComparing first half vs reversed second half:");
        Node head3       = buildLinkedList(listWord);
        Node slow3       = head3;
        Node fast3       = head3;
        while (fast3 != null && fast3.next != null) {
            slow3 = slow3.next;
            fast3 = fast3.next.next;
        }
        Node second = reverseList(slow3);
        Node first  = head3;
        int  cStep  = 1;
        while (second != null) {
            System.out.println("  Step " + cStep + " : first = '" + first.data + "'  second = '" + second.data + "'  Match: " + (first.data == second.data));
            first  = first.next;
            second = second.next;
            cStep++;
        }

        if (isPalindromeLinkedList(listWord)) {
            System.out.println("\n" + listWord + " is a palindrome.");
        } else {
            System.out.println("\n" + listWord + " is not a palindrome.");
        }

        // UC1: Interactive checker
        System.out.println("\n================================");
        System.out.println("     PALINDROME CHECKER v1.0    ");
        System.out.println("================================");
        System.out.println("Checks if a word or phrase reads");
        System.out.println("the same forwards and backwards.");
        System.out.println("Type 'exit' to quit.");
        System.out.println("--------------------------------");

        Scanner scanner = new Scanner(System.in);
        int total = 0, palindromes = 0;

        while (true) {
            System.out.print("\nEnter a word or phrase: ");
            String input = scanner.nextLine();
            if (input.equalsIgnoreCase("exit")) break;
            total++;
            if (isPalindrome(input)) {
                palindromes++;
                System.out.println("✓ \"" + input + "\" IS a palindrome!");
            } else {
                System.out.println("✗ \"" + input + "\" is NOT a palindrome.");
            }
            System.out.println("  Stats: " + palindromes + "/" + total + " palindromes found");
        }

        System.out.println("\n--- Session Summary ---");
        System.out.println("Total checked  : " + total);
        System.out.println("Palindromes    : " + palindromes);
        System.out.println("Not palindromes: " + (total - palindromes));
        System.out.println("Thanks for using Palindrome Checker!");
        scanner.close();
    }
}
