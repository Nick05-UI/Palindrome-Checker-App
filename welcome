import java.util.Scanner;
import java.util.Stack;
import java.util.Queue;
import java.util.LinkedList;
import java.util.Deque;
import java.util.ArrayDeque;

public class PalindromeChecker {

    // UC10: Normalize string (ignore spaces and case)
    public static String normalize(String input) {
        return input.toLowerCase().replaceAll("[^a-z0-9]", "");
    }

    // UC10: Palindrome check with normalization
    public static boolean isPalindromeNormalized(String input) {
        String cleaned = normalize(input);
        return isPalindromeRecursive(cleaned, 0, cleaned.length() - 1);
    }

    // UC9: Recursive palindrome check
    public static boolean isPalindromeRecursive(String input, int start, int end) {
        if (start >= end)                          return true;
        if (input.charAt(start) != input.charAt(end)) return false;
        return isPalindromeRecursive(input, start + 1, end - 1);
    }

    // UC8: Node class
    static class Node {
        char data; Node next;
        Node(char data) { this.data = data; this.next = null; }
    }

    // UC8: Linked list helpers
    public static Node buildLinkedList(String s) {
        Node head = null, tail = null;
        for (char c : s.toCharArray()) {
            Node n = new Node(c);
            if (head == null) { head = tail = n; }
            else { tail.next = n; tail = n; }
        }
        return head;
    }
    public static Node reverseList(Node head) {
        Node prev = null, curr = head;
        while (curr != null) { Node nx = curr.next; curr.next = prev; prev = curr; curr = nx; }
        return prev;
    }
    public static void printList(Node head) {
        System.out.print("[");
        for (Node c = head; c != null; c = c.next)
            System.out.print("'" + c.data + "'" + (c.next != null ? " -> " : ""));
        System.out.println("]");
    }
    public static boolean isPalindromeLinkedList(String s) {
        Node head = buildLinkedList(s), slow = head, fast = head;
        while (fast != null && fast.next != null) { slow = slow.next; fast = fast.next.next; }
        Node second = reverseList(slow), first = buildLinkedList(s);
        while (second != null) { if (first.data != second.data) return false; first = first.next; second = second.next; }
        return true;
    }

    // UC7: Deque
    public static boolean isPalindromeDeque(String s) {
        Deque<Character> d = new ArrayDeque<>();
        for (char c : s.toCharArray()) d.addLast(c);
        while (d.size() > 1) if (d.removeFirst() != d.removeLast()) return false;
        return true;
    }

    // UC6: Queue vs Stack
    public static boolean isPalindromeQueueStack(String s) {
        Stack<Character> st = new Stack<>();
        Queue<Character> q  = new LinkedList<>();
        for (char c : s.toCharArray()) { st.push(c); q.add(c); }
        while (!st.isEmpty()) if (st.pop() != q.poll()) return false;
        return true;
    }

    // UC5: Stack
    public static boolean isPalindromeStack(String s) {
        Stack<Character> st = new Stack<>();
        for (char c : s.toCharArray()) st.push(c);
        String rev = "";
        while (!st.isEmpty()) rev += st.pop();
        return s.equals(rev);
    }

    // UC4: Char array two-pointer
    public static boolean isPalindromeCharArray(String s) {
        char[] ch = s.toCharArray();
        int l = 0, r = ch.length - 1;
        while (l < r) { if (ch[l++] != ch[r--]) return false; }
        return true;
    }

    // UC3: Reverse via loop
    public static String reverseString(String s) {
        String rev = "";
        for (int i = s.length() - 1; i >= 0; i--) rev += s.charAt(i);
        return rev;
    }

    // UC1 & UC2: StringBuilder
    public static boolean isPalindrome(String s) {
        String cl = normalize(s);
        return cl.equals(new StringBuilder(cl).reverse().toString());
    }

    public static void main(String[] args) {

        // UC2
        System.out.println("--- UC2: Hardcoded String Check ---");
        String w = "madam";
        System.out.println(w + (w.equals(new StringBuilder(w).reverse().toString()) ? " is" : " is not") + " a palindrome.");

        // UC3
        System.out.println("\n--- UC3: Reverse Using Loop ---");
        String w3 = "racecar", r3 = reverseString(w3);
        System.out.println("Original : " + w3 + "\nReversed : " + r3);
        System.out.println(w3 + (w3.equals(r3) ? " is" : " is not") + " a palindrome.");

        // UC4
        System.out.println("\n--- UC4: Two-Pointer Char Array ---");
        String w4 = "level";
        char[] ch = w4.toCharArray();
        System.out.print("Char[]   : [");
        for (int i = 0; i < ch.length; i++) System.out.print(ch[i] + (i < ch.length - 1 ? ", " : ""));
        System.out.println("]");
        System.out.println("Comparing pointers:");
        for (int s = 0, e = ch.length - 1; s < e; s++, e--)
            System.out.println("  chars[" + s + "] = '" + ch[s] + "'  vs  chars[" + e + "] = '" + ch[e] + "'");
        System.out.println(w4 + (isPalindromeCharArray(w4) ? " is" : " is not") + " a palindrome.");

        // UC5
        System.out.println("\n--- UC5: Stack-Based Check ---");
        String w5 = "noon";
        Stack<Character> st = new Stack<>();
        System.out.println("Original : " + w5);
        for (char c : w5.toCharArray()) { st.push(c); System.out.println("  Pushed : '" + c + "'  Stack: " + st); }
        String popped = "";
        while (!st.isEmpty()) { char c = st.pop(); popped += c; System.out.println("  Popped : '" + c + "'  Reversed so far: " + popped); }
        System.out.println("Reversed : " + popped);
        System.out.println(w5 + (isPalindromeStack(w5) ? " is" : " is not") + " a palindrome.");

        // UC6
        System.out.println("\n--- UC6: Queue vs Stack (FIFO vs LIFO) ---");
        String w6 = "civic";
        Stack<Character> s6 = new Stack<>();
        Queue<Character> q6 = new LinkedList<>();
        for (char c : w6.toCharArray()) { s6.push(c); q6.add(c); }
        System.out.println("Stack (LIFO) after push    : " + s6);
        System.out.println("Queue (FIFO) after enqueue : " + q6);
        System.out.println("Comparing pop (LIFO) vs dequeue (FIFO):");
        Stack<Character> ts = new Stack<>(); Queue<Character> tq = new LinkedList<>();
        for (char c : w6.toCharArray()) { ts.push(c); tq.add(c); }
        boolean m6 = true;
        while (!ts.isEmpty()) {
            char fs = ts.pop(), fq = tq.poll();
            System.out.println("  Stack.pop() = '" + fs + "'  Queue.poll() = '" + fq + "'  Match: " + (fs == fq));
            if (fs != fq) m6 = false;
        }
        System.out.println(w6 + (m6 ? " is" : " is not") + " a palindrome.");

        // UC7
        System.out.println("\n--- UC7: Deque Front & Rear Comparison ---");
        String w7 = "rotator";
        Deque<Character> dq = new ArrayDeque<>();
        for (char c : w7.toCharArray()) dq.addLast(c);
        System.out.println("Deque after insert : " + dq);
        System.out.println("Comparing front and rear:");
        Deque<Character> td = new ArrayDeque<>();
        for (char c : w7.toCharArray()) td.addLast(c);
        boolean m7 = true; int st7 = 1;
        while (td.size() > 1) {
            char f = td.removeFirst(), r = td.removeLast();
            System.out.println("  Step " + st7++ + " : front = '" + f + "'  rear = '" + r + "'  Match: " + (f == r));
            if (f != r) m7 = false;
        }
        if (td.size() == 1) System.out.println("  Center : '" + td.peekFirst() + "' (middle character, skipped)");
        System.out.println(w7 + (m7 ? " is" : " is not") + " a palindrome.");

        // UC8
        System.out.println("\n--- UC8: Singly Linked List ---");
        String w8 = "kayak";
        System.out.print("Linked List : "); printList(buildLinkedList(w8));
        Node sl = buildLinkedList(w8), fa = sl;
        System.out.println("Finding middle:");
        while (fa != null && fa.next != null) {
            System.out.println("  slow -> '" + sl.data + "'  fast -> '" + fa.data + "'");
            sl = sl.next; fa = fa.next.next;
        }
        System.out.println("  Middle : '" + sl.data + "'");
        Node h2 = buildLinkedList(w8), s2 = h2, f2 = h2;
        while (f2 != null && f2.next != null) { s2 = s2.next; f2 = f2.next.next; }
        System.out.print("Second half reversed : "); printList(reverseList(s2));
        Node h3 = buildLinkedList(w8), s3 = h3, f3 = h3;
        while (f3 != null && f3.next != null) { s3 = s3.next; f3 = f3.next.next; }
        Node sec = reverseList(s3), fir = h3; int cs = 1;
        System.out.println("Comparing halves:");
        while (sec != null) {
            System.out.println("  Step " + cs++ + " : '" + fir.data + "' vs '" + sec.data + "'  Match: " + (fir.data == sec.data));
            fir = fir.next; sec = sec.next;
        }
        System.out.println(w8 + (isPalindromeLinkedList(w8) ? " is" : " is not") + " a palindrome.");

        // UC9
        System.out.println("\n--- UC9: Recursive Check ---");
        String w9 = "refer";
        System.out.println("Original : " + w9 + "\nWinding phase:");
        for (int s = 0, e = w9.length() - 1; s <= e; s++, e--)
            System.out.println(s == e
                ? "  call(" + s + "," + e + ") --> base case '" + w9.charAt(s) + "', return true"
                : "  call(" + s + "," + e + ") --> compare '" + w9.charAt(s) + "' and '" + w9.charAt(e) + "'");
        System.out.println("Unwinding phase:");
        for (int s = w9.length() / 2, e = w9.length() / 2; s >= 0; s--, e++)
            System.out.println(s == e ? "  return true  (base)" : e < w9.length() ? "  return true  <-- '" + w9.charAt(s) + "' == '" + w9.charAt(e) + "'" : "");
        System.out.println(w9 + (isPalindromeRecursive(w9, 0, w9.length() - 1) ? " is" : " is not") + " a palindrome.");

        // UC10: Normalization
        System.out.println("\n--- UC10: Ignore Spaces & Case ---");
        String[] tests = { "A man a plan a canal Panama", "Was it a car or a cat I saw", "Hello World" };
        for (String t : tests) {
            String norm = normalize(t);
            System.out.println("Original   : " + t);
            System.out.println("Normalized : " + norm);
            System.out.println("Result     : " + t + (isPalindromeNormalized(t) ? " is" : " is not") + " a palindrome.\n");
        }

        // UC1: Interactive checker
        System.out.println("================================");
        System.out.println("     PALINDROME CHECKER v1.0    ");
        System.out.println("================================");
        System.out.println("Type 'exit' to quit.");
        System.out.println("--------------------------------");

        Scanner scanner = new Scanner(System.in);
        int total = 0, palindromes = 0;
        while (true) {
            System.out.print("\nEnter a word or phrase: ");
            String input = scanner.nextLine();
            if (input.equalsIgnoreCase("exit")) break;
            total++;
            if (isPalindrome(input)) { palindromes++; System.out.println("✓ \"" + input + "\" IS a palindrome!"); }
            else                     {                 System.out.println("✗ \"" + input + "\" is NOT a palindrome."); }
            System.out.println("  Stats: " + palindromes + "/" + total + " palindromes found");
        }

        System.out.println("\n--- Session Summary ---");
        System.out.println("Total checked  : " + total);
        System.out.println("Palindromes    : " + palindromes);
        System.out.println("Not palindromes: " + (total - palindromes));
        System.out.println("Thanks for using Palindrome Checker!");
        scanner.close();
    }
}
